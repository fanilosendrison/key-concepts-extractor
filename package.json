{
  "name": "key-concepts-extractor",
  "version": "0.1.0",
  "description": "CLI tool to extract key concepts from text via multiple LLM providers, merge results, and expose a web tracking interface",
  "type": "module",
  "bin": {
    "kce": "./src/cli/bin.ts"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "kce": "node --env-file-if-exists=.env --import tsx src/cli/bin.ts"
  },
  "keywords": [
    "cli",
    "llm",
    "concepts",
    "extraction",
    "nlp"
  ],
  "author": "Fanilo Sendrison <fanilo.sendrison@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "msw": "^2.13.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw"
    ]
  },
  "dependencies": {
    "@hono/node-ws": "^1.3.0",
    "fastest-levenshtein": "^1.0.16",
    "hono": "^4.12.14",
    "pino": "^10.3.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
